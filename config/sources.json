  "annotation_schema": {
    "entity_types": [
      {
        "label": "DRUG",
        "description": "Any medication name — brand (Coartem, Efavirenz) or generic (artemether-lumefantrine, amodiaquine)",
        "color": "#4CAF50"
      },
      {
        "label": "ADR",
        "description": "Adverse drug reaction symptom or condition (nausea, oculogyric crisis, hepatotoxicity)",
        "color": "#F44336"
      },
      {
        "label": "SEVERITY",
        "description": "Severity indicator if stated (mild, moderate, severe, fatal, serious, life-threatening)",
        "color": "#FF9800"
      },
      {
        "label": "PATIENT_DEMO",
        "description": "Patient demographics — age, sex, region (19-year-old male, female patient from Ashanti)",
        "color": "#2196F3"
      }
    ],
    "relation_types": [
      {
        "label": "CAUSES",
        "description": "DRUG → causes → ADR",
        "source_entity": "DRUG",
        "target_entity": "ADR"
      }
    ],
    "sentence_labels": [
      {
        "label": "contains_adr",
        "type": "binary",
        "description": "1 if sentence describes or mentions an adverse drug reaction, 0 otherwise"
      }
    ]
  },

